-- Grammar:

UTF8TEXT    <- UTF8CHAR* !.
UTF8CHAR    <- ASCII / DOUBLE / TRIPLE / QUADRUPLE
ASCII       <- [\x00-\x7f]
DOUBLE      <- [\xc0-\xdf] [\x80-\xbf]
TRIPLE      <- [\xe0-\xef] [\x80-\xbf] [\x80-\xbf]
QUADRUPLE   <- [\xf0-\xf7] [\x80-\xbf] [\x80-\xbf] [\x80-\xbf]

